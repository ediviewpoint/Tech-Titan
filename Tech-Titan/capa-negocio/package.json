{
  "name": "tech-titan-negocio",
  "version": "2.0.0",
  "description": "Tech-Titan — API REST pura (Express + PostgreSQL)",
  "scripts": {
    "dev":          "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build":        "tsc --project tsconfig.json",
    "start":        "node dist/server.js",
    "seed":         "ts-node src/scripts/seed-hardware.ts",
    "migrate":      "ts-node src/scripts/migrate.ts up",
    "migrate:down": "ts-node src/scripts/migrate.ts down",
    "setup":        "npm run migrate && npm run seed",
    "test":         "jest --runInBand",
    "test:watch":   "jest --watch",
    "typecheck":    "tsc --noEmit"
  },
  "dependencies": {
    "compression":          "^1.7.4",
    "cors":                 "^2.8.5",
    "dotenv":               "^16.3.1",
    "express":              "^4.18.2",
    "express-rate-limit":   "^7.1.5",
    "helmet":               "^7.1.0",
    "pg":                   "^8.11.3",
    "winston":              "^3.11.0",
    "zod":                  "^3.22.4"
  },
  "devDependencies": {
    "@types/compression":   "^1.7.5",
    "@types/cors":          "^2.8.17",
    "@types/express":       "^4.17.21",
    "@types/jest":          "^29.5.11",
    "@types/node":          "^20.10.0",
    "@types/pg":            "^8.10.9",
    "@types/supertest":     "^6.0.2",
    "jest":                 "^29.7.0",
    "supertest":            "^6.3.4",
    "ts-jest":              "^29.1.1",
    "ts-node":              "^10.9.2",
    "ts-node-dev":          "^2.0.0",
    "typescript":           "^5.3.2"
  }
}
