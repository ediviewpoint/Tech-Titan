# ══════════════════════════════════════════════════════════════════
# Tech-Titan Frontend — Variables de entorno
# Copiá este archivo a .env.local y completá los valores
# ══════════════════════════════════════════════════════════════════

# ── Backend ────────────────────────────────────────────────────────
# URL del backend Express. En Railway: URL pública del servicio backend
NEXT_PUBLIC_API_URL=http://localhost:9000

# ── WhatsApp ───────────────────────────────────────────────────────
# Número en formato internacional SIN + ni espacios
# Bolivia:   591XXXXXXXX  (ej: 59170123456)
# Perú:      51XXXXXXXXX  (ej: 51987654321)
NEXT_PUBLIC_WHATSAPP_NUMBER=59170000000

# ── Auth (NextAuth v5) ─────────────────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET=cambia-esto-por-un-secreto-seguro-de-32-chars

# URL pública del frontend — REQUERIDO en producción
# En Railway: https://tu-app.up.railway.app
NEXTAUTH_URL=http://localhost:3000

# ── OAuth providers (al menos uno requerido para login) ────────────
# GitHub: https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=

# Google: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI (opcional — para el Asistente IA) ──────────────────────────
# Groq: https://console.groq.com/
GROQ_API_KEY=
# OpenAI (alternativo)
OPENAI_API_KEY=
